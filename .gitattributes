# Força LF em todos os arquivos de texto no Git (evita CRLF → UTF-8 corruption)
* text=auto eol=lf

# Arquivos de código — sempre tratados como texto UTF-8
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sql text eol=lf

# Binários — nunca converter
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.webp binary
